# =============================================================================
# ServiceHub — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control — it is .gitignore'd.
# =============================================================================

# --- Database ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=servicehub
DB_USERNAME=servicehub_app
DB_PASSWORD=changeme_use_strong_password

# Read-only user for analytics pipeline
ANALYTICS_DB_USER=analytics_readonly
ANALYTICS_DB_PASSWORD=changeme_analytics_readonly

# --- JWT ---
JWT_SECRET=changeme_generate_a_256bit_secret_key_here_minimum_32_characters
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- File Uploads ---
FILE_UPLOAD_DIR=/data/servicehub/uploads
FILE_MAX_SIZE_MB=5
FILE_MAX_PER_REQUEST=5

# --- Email (SMTP) ---
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@servicehub.local
MAIL_ENABLED=true

# --- Frontend ---
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=dev

# --- pgAdmin (dev only) ---
PGADMIN_EMAIL=admin@servicehub.local
PGADMIN_PASSWORD=admin
